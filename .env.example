# ==========================================
# SportsPlatform 環境設定
# 複製為 .env 並填入實際值
# ==========================================

# --- 資料庫 ---
DB_ROOT_PASS=rootpassword
DB_USER=sports_user
DB_PASS=sports_pass
DB_HOST=mysql
DB_PORT=3306
DB_NAME=sports_platform

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE_HOURS=168

# --- MinIO 圖片儲存 ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=sports-platform

# --- 網站網址 ---
APP_FRONTEND_URL=https://yourdomain.com
APP_ADMIN_URL=https://admin.yourdomain.com
APP_ENV=production

# --- 後台初始超級管理員（首次啟動自動建立）---
ADMIN_INIT_USERNAME=superadmin
ADMIN_INIT_EMAIL=admin@yourdomain.com
ADMIN_INIT_PASSWORD=ChangeMe@2025
ADMIN_INIT_NAME=超級管理員

# --- 金流 ECPay 綠界（上線前填入）---
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_IS_SANDBOX=true
ECPAY_RETURN_URL=https://yourdomain.com/payment/result

# --- Garmin OAuth 1.0a（上線前填入）---
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
