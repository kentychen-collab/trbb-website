# ═══════════════════════════════════════════════════════════
# TRBB .gitignore
# ═══════════════════════════════════════════════════════════

# ── OS / Editor ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*~
*.swp
*.swo
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Node.js / Frontend ──────────────────────────────────────
node_modules/
frontend/web/node_modules/
frontend/app/node_modules/
frontend/admin/node_modules/
frontend/web/dist/
frontend/app/dist/
frontend/admin/dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
.cache/

# ── Go / Backend ────────────────────────────────────────────
backend/trbb-server
backend/*.exe
backend/vendor/
*.test
*.out
coverage.out
*.prof

# ── Docker Volume Data ──────────────────────────────────────
mysql/data/
redis/data/
minio/data/

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
nginx/logs/

# ── Build Artifacts ─────────────────────────────────────────
*.tar.gz
*.zip
dist/
build/
tmp/
temp/

# ── Certificates / SSL ──────────────────────────────────────
nginx/ssl/
certs/

# ── Misc ─────────────────────────────────────────────────────
.git/
*.bak
*.orig
*.rej
