# ── App ────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8080
APP_SECRET_KEY=YourJwtSecretKeyAtLeast32CharactersLong!

# ── MySQL ──────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=trbb_pro
DB_USER=trbb_pro
DB_PASSWORD=YourDbPassword@2024!
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YourRedisPassword@2024!
REDIS_DB=0
REDIS_POOL_SIZE=10

# ── MinIO ──────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=trbb_minio
MINIO_SECRET_KEY=YourMinioPassword@2024!
MINIO_USE_SSL=false
MINIO_BUCKET_PUBLIC=trbb-public
MINIO_BUCKET_PRIVATE=trbb-private
MINIO_BUCKET_IMAGES=images
MINIO_EXTERNAL_URL=http://images.trbbtw.com

# ── Log ────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/app/logs

# ── Payment ────────────────────────────────────────────────
PAYMENT_PROVIDER=ecpay
PAYMENT_MERCHANT_ID=CHANGEME
PAYMENT_HASH_KEY=CHANGEME
PAYMENT_HASH_IV=CHANGEME
PAYMENT_RETURN_URL=https://trbbtw.com/v1/third/payment/callback
PAYMENT_NOTIFY_URL=https://trbbtw.com/v1/third/payment/notify

# ── Garmin ─────────────────────────────────────────────────
GARMIN_CLIENT_ID=CHANGEME
GARMIN_CLIENT_SECRET=CHANGEME
GARMIN_REDIRECT_URI=https://trbbtw.com/v1/third/garmin/callback
GARMIN_AUTH_URL=https://connect.garmin.com/oauthConfirm
GARMIN_TOKEN_URL=https://connectapi.garmin.com/oauth-service/oauth/token
GARMIN_API_BASE=https://healthapi.garmin.com/wellness-api/rest

# ── LINE ───────────────────────────────────────────────────
LINE_NOTIFY_TOKEN=CHANGEME
LINE_CHANNEL_ID=CHANGEME
LINE_CHANNEL_SECRET=CHANGEME

# ── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGEME
GOOGLE_CLIENT_SECRET=CHANGEME
GOOGLE_REDIRECT_URI=https://trbbtw.com/v1/third/google/callback

# ── Facebook OAuth ─────────────────────────────────────────
FB_APP_ID=CHANGEME
FB_APP_SECRET=CHANGEME
FB_REDIRECT_URI=https://trbbtw.com/v1/third/facebook/callback

# ── Email (SendGrid) ───────────────────────────────────────
SENDGRID_API_KEY=CHANGEME
EMAIL_FROM=noreply@trbbtw.com
EMAIL_FROM_NAME=TRBB 鐵人三項運動社團

# ── SMS ────────────────────────────────────────────────────
SMS_PROVIDER=every8d
SMS_UID=CHANGEME
SMS_PWD=CHANGEME
SMS_FROM=TRBB

# ── Strava OAuth 2.0 ────────────────────────────────────────
STRAVA_CLIENT_ID=253105
STRAVA_CLIENT_SECRET=5d71c8c4af41a9ee915a6f3b6d2fdbfd8d7c725c
STRAVA_REDIRECT_URI=https://trbbtw.com/v1/third/strava/callback
STRAVA_AUTH_URL=https://www.strava.com/oauth/authorize
STRAVA_TOKEN_URL=https://www.strava.com/oauth/token
STRAVA_API_BASE=https://www.strava.com/api/v3
